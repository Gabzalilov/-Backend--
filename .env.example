APP_NAME=Developer Portfolio API
APP_ENV=development
DEBUG=false
HOST=127.0.0.1
PORT=8000
DATABASE_PATH=data/app.db
LOG_PATH=logs/app.log

# Exact origins only. Never use "*" together with credentials.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
TRUST_PROXY_HEADERS=false

# Per client IP in a fixed window.
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=3600
RATE_LIMIT_SALT=replace-with-a-long-random-value

# Free local DeepSeek via Ollama. The deterministic fallback keeps requests alive.
AI_ENABLED=true
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=deepseek-r1:1.5b
AI_TIMEOUT_SECONDS=120

# "log" writes .eml files locally; "smtp" sends real email.
EMAIL_DELIVERY_MODE=log
SITE_OWNER_EMAIL=owner@example.com
MAIL_FROM_EMAIL=no-reply@example.com
MAIL_FROM_NAME=Developer Portfolio
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10
OUTBOX_PATH=outbox

# Protects GET /api/metrics.
METRICS_API_KEY=replace-with-a-random-metrics-key
